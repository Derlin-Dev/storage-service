# Copia este archivo a .env y ajusta los valores.
# .env NO debe subirse al repo (agrégalo a .gitignore si no está ya).

# --- Postgres ---
POSTGRES_DB=file_store_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123

# --- JWT ---
# Genera uno nuevo, por ejemplo: openssl rand -hex 32
JWT_SECRET=7cd11f886cee77016bcb10b9d70880bd4951a4ccaffb7766a637a460ecef2b4a
JWT_EXPIRATION_MINUTES=60

# --- URLs públicas ---
APP_BASE_URL=http://localhost:8080
APP_FRONTEND_URL=http://localhost:5173

# --- MinIO / S3 ---
# "minio" debe existir en tu /etc/hosts apuntando a 127.0.0.1 (ver README-docker.md)
STORAGE_ENDPOINT=http://minio:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=files
STORAGE_ACCESS_KEY=admin
STORAGE_SECRET_KEY=admin123456